CLEAR_CONSOLE

Variables <- "heheheheheh"

FUNCTION fibonacci(times)
    a <- 0
    b <- 1
    
    FOR i FROM 1 TO times
        temp <- a
        a <- b
        b <- temp + b
    END FOR

    RETURN a
END FUNCTION 

DISPLAY fibonacci(10) // Should display 55

